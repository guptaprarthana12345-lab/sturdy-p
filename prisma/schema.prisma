generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id     Int     @id @default(autoincrement())
  name   String
  habits Habit[]
}

model Habit {
  id        Int      @id @default(autoincrement())
  name      String
  streak    Int      @default(0)
  xpValue   Int      @default(10)
  completed Boolean  @default(false)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}
